#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running type check..."
npm run type-check || exit 1

echo "✅ Type check passed"
echo "🧪 Running tests..."
npm run test || exit 1

echo "✅ Tests passed"
echo "🏗️  Building project..."
npm run build || exit 1

echo "✅ Build succeeded"
echo ""
echo "🎉 All checks passed! Push allowed."
